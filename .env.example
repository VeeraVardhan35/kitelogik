# ── Required ──────────────────────────────────────────────────────────────────
# Anthropic API key — needed to run the demo and any agent session.
# Get yours at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Optional — defaults shown ─────────────────────────────────────────────────
# OPA policy engine URL. Change if OPA is running on a non-default port.
# Only needed when using OPAClient (server mode). Not needed with RegorusClient.
# OPA_BASE_URL=http://localhost:8181

# Path to the HITL SQLite database (created automatically on first run).
# HITL_DB_PATH=hitl.db

# Path to the agent memory SQLite database.
# MEMORY_DB_PATH=memory.db

# Path to the audit log SQLite database.
# AUDIT_DB_PATH=audit.db

# How long (seconds) a HITL action waits for human approval before timing out.
# HITL_TIMEOUT_SECONDS=300
