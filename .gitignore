# ── Kite Logik — enterprise staging ─────────────────────────────────────────
# Enterprise-only source files waiting to be extracted to kitelogik-enterprise.
# Must never appear in the public OSS repo.
enterprise_staging/

# ── Kite Logik — runtime databases ───────────────────────────────────────────
# These are generated at runtime and must never be committed.
# They may contain session state, credentials, and audit records.
*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ── Kite Logik — secrets ─────────────────────────────────────────────────────
# .env holds API keys and service credentials. .env.example is safe to commit.
# The !.env.example line below explicitly allows it despite the .env rule above.
../kite_logik_demo/.env
.env.*
!.env.example

# ── Kite Logik — trace output ────────────────────────────────────────────────
traces/
*.otlp
*.jsonl

